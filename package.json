{
  "name": "tiktok-manager",
  "version": "1.0.6",
  "description": "Planification et programmation de vidéos et stories TikTok",
  "author": "TikTok Manager",
  "private": true,
  "main": "dist-electron/electron/main.js",
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "build:renderer": "vite build",
    "build:electron": "tsc -p tsconfig.electron.json",
    "build": "npm run build:renderer && npm run build:electron",
    "dist": "npm run build && electron-builder --win nsis"
  },
  "dependencies": {
    "date-fns": "^3.6.0",
    "electron-updater": "^6.8.9",
    "ffmpeg-static": "^5.2.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.26.2",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@types/node": "^20.16.5",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@types/uuid": "^9.0.8",
    "@vitejs/plugin-react": "^4.3.1",
    "electron": "^31.6.0",
    "electron-builder": "^24.13.3",
    "jimp": "^1.6.1",
    "to-ico": "^1.1.5",
    "typescript": "^5.5.4",
    "vite": "^5.4.4"
  }
}
